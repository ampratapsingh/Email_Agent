# ─────────────────────────────────────────────────────────────────────────────
# Finance Credit Follow-Up Email Agent — Environment Configuration
# Copy this file to .env and fill in your values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider (choose one) ─────────────────────────────────────────────────
# Option A: Google Gemini (recommended — free tier available)
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Option B: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Active LLM provider: "gemini" | "openai"
LLM_PROVIDER=gemini

# Model name
# Gemini options:  gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-exp
# OpenAI options:  gpt-4o, gpt-4o-mini, gpt-3.5-turbo
LLM_MODEL=gemini-2.0-flash-exp

# ── Email Sending Configuration ───────────────────────────────────────────────
# Set DRY_RUN=true to simulate sending (no real emails sent — SAFE for testing)
DRY_RUN=true

# SMTP credentials (only used when DRY_RUN=false)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com
EMAIL_FROM_NAME=Finance Team

# ── Payment Link Template ─────────────────────────────────────────────────────
# {invoice_no} will be substituted automatically
PAYMENT_LINK_BASE=https://pay.yourcompany.com/invoice/

# Finance contact for escalated invoices
FINANCE_MANAGER_EMAIL=finance-manager@yourcompany.com
FINANCE_MANAGER_NAME=Finance Manager

# ── Data Source ───────────────────────────────────────────────────────────────
# Path to your CSV/Excel file with invoice records
DATA_FILE=data/invoices.csv

# ── Audit Database ────────────────────────────────────────────────────────────
AUDIT_DB_PATH=audit/audit_trail.db

# ── LangSmith Observability (optional — bonus marks) ─────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_PROJECT=finance-email-agent
